IMAGE;VALUE=URI;DISPLAY=BADGE;FMTTYPE=image/jpeg:https://events.rice.edu/li
 ve/image/gid/214/width/80/height/80/crop/1/src_region/0/,0/,400/,400/12094
 _1706193979695.rev.1777928140.jpg
ATTACH;FMTTYPE=image/jpeg:https://events.rice.edu/live/image/gid/214/width/
 80/height/80/crop/1/src_region/0/,0/,400/,400/12094_1706193979695.rev.1777

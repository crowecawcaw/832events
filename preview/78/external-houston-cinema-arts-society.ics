					<div id="text-1036" class="widget widget_text"><h4 class="widgettitle">Newsletter Signup</h4>			<div class="textwidget">
	<section id="yikes-mailchimp-container-3" class="yikes-mailchimp-container yikes-mailchimp-container-3 ">

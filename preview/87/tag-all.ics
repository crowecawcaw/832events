	n\n\n11:00 am Classes\n\n\n\n\n\n\n\n\nJune 4 – 11:00 am\n\n\n\n\n\nJune 1
	1 – 11:00 am\n\n\n\n\n\nJune 18 – 11:00 am\n\n\n\n\n\nJune 25 – 11:00 am\n
	\n\n\n\n\nJUly 2 – 11:00 am\n\n\n\n\n\nJuly 9 – 11:00 am\n\n\n\n\n\nJuly 1
